# Owlet Cam bridge config. Copy this file to .env and fill in your values:
#     cp .env.sample .env
# .env is gitignored; this sample is safe to commit.

# --- required: your camera's credentials (from tools/capture_auth) ---
TUTK_UID=
AUTH_KEY=
PASSWORD=

# --- required: Owlet's Kalay SDK license key (from tools/extractkey) ---
SDK_KEY=

# --- optional tunables (defaults shown) ---
# AV_ACCOUNT=admin
# CHANNEL=0
# QUALITY=high        # max|high|hd|middle|sd|low|ld
# AUDIO=1             # 0 to disable audio
# HTTP_PORT=8091
# TLS=1               # 1 self-signed HTTPS, 0 plain HTTP
# TLS_CERT=           # path to a real cert PEM (optional)
# TLS_KEY=            # path to a real key PEM (optional)
# LAN_ONLY=1          # 1 never contact the cloud, 0 allow rendezvous
# LAN_PORT=63616
# IDLE_TIMEOUT=600    # seconds to keep the camera warm after the last viewer leaves
